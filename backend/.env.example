# ====================================================
# GridsPilot OS - Environment Variables Template
# 复制此文件并重命名为 .env，然后填入你的真实 Key
# ====================================================

# 1. LLM API Keys (如果你打算在后端的 llm.py 中作为默认 Fallback)
OPENAI_API_KEY="sk-your-openai-api-key-here"
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DASHSCOPE_API_KEY="sk-your-qwen-api-key-here"

# 2. Database (Production Ready) - 未来预留
# STORAGE_TYPE="file" # options: "file", "postgres"
# DATABASE_URL="postgresql://user:password@localhost:5432/GridsPilot"

# 3. Message Queue (Production Ready) - 未来预留
