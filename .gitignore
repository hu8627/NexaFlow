# =========================
# 1. 环境变量与私密配置
# =========================
.env
.env.local
.env.*.local
*.pem
*.key

# =========================
# 2. 核心大坑：底层业务数据 (FileDB & SQLite)
# 绝对不能把包含真实 Key 和业务隐私的 JSON 和 DB 传上去！
# =========================
backend/data/**/*.json
backend/data/**/*.db
backend/data/**/*.sqlite
backend/data/**/*.sqlite3
!backend/data/**/.gitkeep

# =========================
# 3. Python 后端缓存与构建产物
# =========================
backend/venv/
backend/env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
backend/build/
backend/dist/
backend/*.spec
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/

# =========================
# 4. 前端依赖与构建产物
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# 5. Tauri 桌面端编译产物 (防体积爆炸)
# =========================
frontend/src-tauri/target/
frontend/src-tauri/bin/GridsPilot-engine*
frontend/src-tauri/bin/*.exe

# =========================
